# --- Master ---
# Local Postgres:
#   DATABASE_URL=postgres://vajra:vajra@localhost:5432/vajra?sslmode=disable
# AWS RDS Postgres:
#   DATABASE_URL=postgres://vajra:PASSWORD@vajra-db.xxxxx.ap-south-1.rds.amazonaws.com:5432/vajra?sslmode=require
export DATABASE_URL="postgres://vajra:vajra@localhost:5432/vajra?sslmode=disable"
export JWT_SECRET="dev-secret-change-in-production-please-use-32-chars-min"
export AGENT_SHARED_SECRET="dev-agent-secret-please-32chars-minimum-pls"
export PUBLIC_BASE_DOMAIN="localhost"
export LISTEN_ADDR=":8080"
export ADMIN_ACCOUNT_ID=""

# Optional Redis cache. Leave empty to fall through to Postgres on every
# read (current behaviour). When set, hot-path lookups (sandbox state,
# node usage, account quota counts, template metadata) are cached.
export REDIS_URL=""

# Optional NATS event bus. Leave empty to keep the existing HTTP
# heartbeat path. When set, agents publish heartbeats and state events
# to NATS, master subscribes and writes through to Redis + Postgres.
export NATS_URL=""

# --- Agent ---
export VAJRA_AGENT_MASTER_URL="http://localhost:8080"
export VAJRA_AGENT_API_KEY="dev-agent-secret-please-32chars-minimum-pls"
export VAJRA_AGENT_LISTEN_ADDR=":9000"
export VAJRA_AGENT_CACHE_DIR="/var/lib/vajra/cache"
export VAJRA_AGENT_SANDBOX_ROOT="/var/lib/vajra/sandboxes"
export VAJRA_AGENT_SOCKET_DIR="/tmp/vajra/sockets"
export VAJRA_AGENT_CH_BINARY="/usr/local/bin/cloud-hypervisor"
export VAJRA_AGENT_TOTAL_CPU=2
export VAJRA_AGENT_TOTAL_MEMORY_MB=3500
export VAJRA_AGENT_TOTAL_DISK_GB=20
export VAJRA_AGENT_CLUSTER_ID="cluster-1"

# --- S3 archive storage ---
# Leave VAJRA_S3_BUCKET empty to keep archives on the local filesystem only.
export VAJRA_S3_BUCKET=""
export VAJRA_S3_REGION=""
export VAJRA_S3_PREFIX=""
export AWS_ACCESS_KEY_ID=""
export AWS_SECRET_ACCESS_KEY=""

# --- Autoscaler (optional) ---
# When VAJRA_AUTOSCALE_ENABLED=true, a sandbox create that hits
# "no node has capacity" no longer returns 503. Instead, master:
#   1. Rejects with 400 if the request exceeds the largest known node
#      type (currently 16 vCPU / 32 GB RAM).
#   2. Persists the sandbox in state=CREATING with no node placement.
#   3. Launches an EC2 instance sized for the request and waits for the
#      new agent to register.
#   4. Schedules + dispatches the sandbox on the fresh node.
#   5. The user polls GET /v1/sandboxes/{id} until state=RUNNING (EC2
#      boot + agent register typically 2-3 minutes).
#
# Disabled (default): no-capacity returns 503 with a friendlier message
# telling the user to wait for the auto-scaler instead of the raw error.
#
# VAJRA_AUTOSCALE_INSTANCE_TYPE is an OPERATOR OVERRIDE. Leave empty to
# let master pick the smallest type that fits the request from this
# ladder. c8i.* is required because nested virtualization (needed for
# cloud-hypervisor + KVM) is only available on c8i / .metal on Intel:
#   <= 2 vCPU,  4 GB RAM  -> c8i.large    (2 vCPU,  4 GB)
#   <= 4 vCPU,  8 GB RAM  -> c8i.xlarge   (4 vCPU,  8 GB)
#   <= 8 vCPU, 16 GB RAM  -> c8i.2xlarge  (8 vCPU, 16 GB)
#   <= 16 vCPU, 32 GB RAM -> c8i.4xlarge (16 vCPU, 32 GB)
#
# RunInstances always sets CpuOptions.NestedVirtualization=enabled on
# the launched node — without it the guest can't see KVM and CH will
# exit with "no supported hypervisor".
#
# VAJRA_BINARY_DIR (set on the master) points at a directory containing
# `vajra-agent` and `cloud-hypervisor`. Master serves them via
# GET /internal/binaries/{name} behind the shared agent secret so
# autoscaled nodes can bootstrap without an IAM instance profile or
# public S3.
#
# VAJRA_AUTOSCALE_ROOT_VOLUME_GB overrides the AMI's default root
# volume. Defaults to 0 (inherit the AMI), but the snapshot-restore
# path needs ~30 GB of free space on top of the AMI install, so most
# deployments want this set explicitly (we use 100 GB in production).
# The new volume is gp3, giving 3000 baseline IOPS / 125 MB/s — that
# cuts cold-cache restore time from ~31s on gp2 to ~23s.
export VAJRA_AUTOSCALE_ENABLED="true"
export VAJRA_AUTOSCALE_AMI=""
export VAJRA_AUTOSCALE_INSTANCE_TYPE=""
export VAJRA_AUTOSCALE_REGION="ap-south-1"
export VAJRA_AUTOSCALE_SG=""
export VAJRA_AUTOSCALE_KEY="mini-daytona-key"
export VAJRA_AUTOSCALE_SUBNET=""
# Legacy aliases kept for parity with existing deployments. main.go still
# reads the *_GROUP / *_PAIR / *_ID forms — set whichever you prefer.
export VAJRA_AUTOSCALE_SECURITY_GROUP=""
export VAJRA_AUTOSCALE_KEY_PAIR=""
export VAJRA_AUTOSCALE_SUBNET_ID=""
export VAJRA_AUTOSCALE_MASTER_URL="http://master.internal:8080"
export VAJRA_AUTOSCALE_CLUSTER_ID="cluster-1"
export VAJRA_AUTOSCALE_S3_BUCKET=""
export VAJRA_AUTOSCALE_MIN_NODES="1"
export VAJRA_AUTOSCALE_MAX_NODES="10"
export VAJRA_AUTOSCALE_COOLDOWN="15"
# CooldownMins is the legacy alias for VAJRA_AUTOSCALE_COOLDOWN.
export VAJRA_AUTOSCALE_COOLDOWN_MINS="15"
export VAJRA_AUTOSCALE_ROOT_VOLUME_GB="100"
export VAJRA_BINARY_DIR="/home/ubuntu/vajra/bin"
